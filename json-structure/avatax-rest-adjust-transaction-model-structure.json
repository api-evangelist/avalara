        "NotAdjusted",
        "SourcingIssue",
        "ReconciledWithGeneralLedger",
        "ExemptCertApplied",
        "PriceAdjusted",
        "ProductReturned",
        "ProductExchanged",
        "BadDebt",
        "Other"
      ]
    },
    "adjustmentDescription": {
      "type": "string"
    },
    "newTransaction": {
      "$ref": "#/components/schemas/CreateTransactionModel"
    }
  },
  "name": "AdjustTransactionModel"
}