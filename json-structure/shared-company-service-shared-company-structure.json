{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/avalara/refs/heads/main/json-structure/shared-company-service-shared-company-structure.json",
  "description": "SharedCompany schema from Avalara API",
  "type": "object",
  "properties": {
    "companyId": {
      "type": "string"
    },
    "companyName": {
      "type": "string"
    },
    "companyCode": {
      "type": "string"
    },
    "taxPayerId": {
      "type": "string",
      "description": "Tax identification number"
    },
    "address": {
      "type": "object",
      "properties": {
        "line1": {
          "type": "string"
        },
        "line2": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "region": {
          "type": "string"
        },
        "postalCode": {
          "type": "string"
        },
        "country": {
          "type": "string"
        }
      }
    },
    "phoneNumber": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "isActive": {
      "type": "boolean"
    },
    "createdDate": {
      "type": "datetime"
    },
    "modifiedDate": {
      "type": "datetime"
    }
  },
  "name": "SharedCompany"
}