{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/avalara/refs/heads/main/json-structure/avatax-rest-location-model-structure.json",
  "description": "LocationModel schema from Avalara API",
  "type": "object",
  "properties": {
    "id": {
      "type": "int32"
    },
    "companyId": {
      "type": "int32"
    },
    "locationCode": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "addressTypeId": {
      "type": "string",
      "enum": [
        "Firm",
        "Location",
        "Salesperson"
      ]
    },
    "addressCategoryId": {
      "type": "string",
      "enum": [
        "Storefront",
        "MainOffice",
        "Warehouse",
        "Salesperson",
        "Other"
      ]
    },
    "line1": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "region": {
      "type": "string"
    },
    "postalCode": {
      "type": "string"
    },
    "country": {
      "type": "string"
    }
  },
  "name": "LocationModel"
}