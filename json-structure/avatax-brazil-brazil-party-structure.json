{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/avalara/refs/heads/main/json-structure/avatax-brazil-brazil-party-structure.json",
  "description": "BrazilParty schema from Avalara API",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "cnpj": {
      "type": "string",
      "description": "Company tax ID (CNPJ)"
    },
    "cpf": {
      "type": "string",
      "description": "Individual tax ID (CPF)"
    },
    "stateRegistration": {
      "type": "string",
      "description": "Inscricao Estadual"
    },
    "municipalRegistration": {
      "type": "string",
      "description": "Inscricao Municipal"
    },
    "address": {
      "type": "object",
      "properties": {
        "street": {
          "type": "string"
        },
        "number": {
          "type": "string"
        },
        "complement": {
          "type": "string"
        },
        "neighborhood": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "cityCode": {
          "type": "string",
          "description": "IBGE city code"
        },
        "state": {
          "type": "string",
          "description": "State code (UF)"
        },
        "postalCode": {
          "type": "string"
        },
        "country": {
          "type": "string"
        }
      }
    }
  },
  "name": "BrazilParty"
}