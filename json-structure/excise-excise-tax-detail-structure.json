      "type": "double"
    },
    "taxableAmount": {
      "type": "double"
    },
    "exemptAmount": {
      "type": "double"
    },
    "rateType": {
      "type": "string",
      "enum": [
        "PerUnit",
        "Percentage"
      ]
    }
  },
  "name": "ExciseTaxDetail"
}