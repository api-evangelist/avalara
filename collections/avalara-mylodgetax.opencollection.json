{
  "opencollection": "1.0.0",
  "info": {
    "name": "Avalara MyLodgeTax API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Tax Rates",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Avalara Get Lodging Tax Rates",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.avalara.com/mylodgetax/v1/tax-rates",
            "params": [
              {
                "name": "line1",
                "value": "",
                "type": "query",
                "description": "Street address"
              },
              {
                "name": "city",
                "value": "",
                "type": "query"
              },
              {
                "name": "region",
                "value": "",
                "type": "query",
                "description": "State or province"
              },
              {
                "name": "postalCode",
                "value": "",
                "type": "query"
              },
              {
                "name": "country",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Returns applicable lodging and short-term rental tax rates for a given property location, broken down by jurisdiction."
        }
      ]
    },
    {
      "info": {
        "name": "Properties",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Avalara List Registered Properties",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.avalara.com/mylodgetax/v1/properties"
          },
          "docs": "Avalara List Registered Properties"
        },
        {
          "info": {
            "name": "Avalara Register a Rental Property",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.avalara.com/mylodgetax/v1/properties",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Avalara Register a Rental Property"
        }
      ]
    },
    {
      "info": {
        "name": "Obligations",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Avalara Get Filing Obligations for a Property",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.avalara.com/mylodgetax/v1/properties/:propertyId/obligations",
            "params": [
              {
                "name": "propertyId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Returns a summary of tax filing obligations for a registered property, including which taxes apply and filing frequencies."
        }
      ]
    }
  ],
  "bundled": true
}