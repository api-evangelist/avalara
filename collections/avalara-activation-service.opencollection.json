{
  "opencollection": "1.0.0",
  "info": {
    "name": "Avalara Activation Service API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Registrations",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Avalara List All Registrations",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.avalara.com/activation/v1/registrations",
            "params": [
              {
                "name": "status",
                "value": "",
                "type": "query"
              },
              {
                "name": "$top",
                "value": "",
                "type": "query"
              },
              {
                "name": "$skip",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Retrieves all registrations for the authenticated partner."
        },
        {
          "info": {
            "name": "Avalara Get a Registration by ID",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.avalara.com/activation/v1/registrations/:registrationId",
            "params": [
              {
                "name": "registrationId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Retrieves details for a specific registration."
        }
      ]
    }
  ],
  "bundled": true
}