{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/OAuthError",
  "title": "OAuthError",
  "type": "object",
  "properties": {
    "error": {
      "type": "string",
      "enum": [
        "invalid_request",
        "invalid_client",
        "invalid_grant",
        "unauthorized_client",
        "unsupported_grant_type",
        "invalid_scope"
      ]
    },
    "error_description": {
      "type": "string"
    }
  }
}