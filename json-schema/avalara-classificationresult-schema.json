{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ClassificationResult",
  "title": "ClassificationResult",
  "type": "object",
  "properties": {
    "itemCode": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "hsCode": {
      "type": "string",
      "description": "Classified HS Code"
    },
    "hsCodeDescription": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "format": "double",
      "description": "Classification confidence score (0-1)"
    },
    "country": {
      "type": "string"
    }
  }
}