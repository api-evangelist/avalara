{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/avalara/refs/heads/main/json-schema/e-invoicing-document-status-schema.json",
  "title": "DocumentStatus",
  "description": "DocumentStatus schema from Avalara API",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Pending",
        "Accepted",
        "Rejected",
        "Error"
      ]
    },
    "statusDate": {
      "type": "string",
      "format": "date-time"
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/DocumentEvent"
      }
    }
  }
}