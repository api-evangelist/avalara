{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/avalara/refs/heads/main/json-schema/hs-code-classification-classification-prediction-schema.json",
  "title": "ClassificationPrediction",
  "description": "ClassificationPrediction schema from Avalara API",
  "type": "object",
  "properties": {
    "hsCode": {
      "type": "string",
      "description": "Predicted HS Code"
    },
    "description": {
      "type": "string",
      "description": "HS Code description"
    },
    "confidence": {
      "type": "number",
      "format": "double",
      "description": "Confidence score (0-1)"
    },
    "parentCode": {
      "type": "string"
    }
  }
}