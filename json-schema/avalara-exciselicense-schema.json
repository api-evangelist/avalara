{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ExciseLicense",
  "title": "ExciseLicense",
  "type": "object",
  "properties": {
    "licenseId": {
      "type": "string"
    },
    "licenseNumber": {
      "type": "string"
    },
    "licenseType": {
      "type": "string"
    },
    "issuingJurisdiction": {
      "type": "string"
    },
    "effectiveDate": {
      "type": "string",
      "format": "date"
    },
    "expirationDate": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": [
        "Active",
        "Expired",
        "Suspended",
        "Revoked"
      ]
    }
  }
}