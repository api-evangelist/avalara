{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/FilingObligation",
  "title": "FilingObligation",
  "type": "object",
  "properties": {
    "jurisdiction": {
      "type": "string"
    },
    "taxType": {
      "type": "string"
    },
    "filingFrequency": {
      "type": "string",
      "enum": [
        "Monthly",
        "Quarterly",
        "Annual"
      ]
    },
    "nextDueDate": {
      "type": "string",
      "format": "date"
    },
    "registrationRequired": {
      "type": "boolean"
    },
    "registrationUrl": {
      "type": "string"
    }
  }
}