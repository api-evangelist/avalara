{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/TaxRateModel",
  "title": "TaxRateModel",
  "type": "object",
  "properties": {
    "totalRate": {
      "type": "number",
      "format": "double",
      "description": "Total combined tax rate"
    },
    "rates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "rate": {
            "type": "number",
            "format": "double"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "Country",
              "State",
              "County",
              "City",
              "Special"
            ]
          }
        }
      }
    }
  }
}