{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ClassificationItem",
  "title": "ClassificationItem",
  "type": "object",
  "required": [
    "description"
  ],
  "properties": {
    "itemCode": {
      "type": "string",
      "description": "Unique item identifier"
    },
    "description": {
      "type": "string",
      "description": "Product description for classification"
    },
    "summary": {
      "type": "string",
      "description": "Short product summary"
    },
    "attributes": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Additional product attributes for classification"
    }
  }
}