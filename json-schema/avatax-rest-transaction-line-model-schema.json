    "lineAmount": {
      "type": "number",
      "format": "double"
    },
    "tax": {
      "type": "number",
      "format": "double"
    },
    "taxableAmount": {
      "type": "number",
      "format": "double"
    },
    "exemptAmount": {
      "type": "number",
      "format": "double"
    },
    "taxCode": {
      "type": "string"
    },
    "itemCode": {
      "type": "string"
    }
  }
}