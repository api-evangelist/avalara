{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/SharedCompany",
  "title": "SharedCompany",
  "type": "object",
  "properties": {
    "companyId": {
      "type": "string"
    },
    "companyName": {
      "type": "string"
    },
    "companyCode": {
      "type": "string"
    },
    "taxPayerId": {
      "type": "string",
      "description": "Tax identification number"
    },
    "address": {
      "type": "object",
      "properties": {
        "line1": {
          "type": "string"
        },
        "line2": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "region": {
          "type": "string"
        },
        "postalCode": {
          "type": "string"
        },
        "country": {
          "type": "string"
        }
      }
    },
    "phoneNumber": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "isActive": {
      "type": "boolean"
    },
    "createdDate": {
      "type": "string",
      "format": "date-time"
    },
    "modifiedDate": {
      "type": "string",
      "format": "date-time"
    }
  }
}