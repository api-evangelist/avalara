{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/BrazilCompany",
  "title": "BrazilCompany",
  "type": "object",
  "properties": {
    "companyId": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "cnpj": {
      "type": "string"
    },
    "stateRegistration": {
      "type": "string"
    },
    "municipalRegistration": {
      "type": "string"
    },
    "taxRegime": {
      "type": "string",
      "enum": [
        "SimplesNacional",
        "LucroPresumido",
        "LucroReal"
      ]
    },
    "state": {
      "type": "string"
    }
  }
}