{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/OrderResponse",
  "title": "OrderResponse",
  "type": "object",
  "properties": {
    "orderId": {
      "type": "string"
    },
    "accountId": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Pending",
        "Confirmed",
        "Completed",
        "Cancelled"
      ]
    },
    "createdDate": {
      "type": "string",
      "format": "date-time"
    }
  }
}