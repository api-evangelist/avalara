{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/CertificateModel",
  "title": "CertificateModel",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "companyId": {
      "type": "integer"
    },
    "signedDate": {
      "type": "string",
      "format": "date"
    },
    "expirationDate": {
      "type": "string",
      "format": "date"
    },
    "exemptionNumber": {
      "type": "string"
    },
    "exemptPercentage": {
      "type": "number",
      "format": "double"
    },
    "exemptionReason": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "status": {
      "type": "string"
    },
    "createdDate": {
      "type": "string",
      "format": "date-time"
    },
    "modifiedDate": {
      "type": "string",
      "format": "date-time"
    }
  }
}