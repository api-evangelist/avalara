{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/avalara/refs/heads/main/json-schema/avatax-rest-location-model-schema.json",
  "title": "LocationModel",
  "description": "LocationModel schema from Avalara API",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "companyId": {
      "type": "integer"
    },
    "locationCode": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "addressTypeId": {
      "type": "string",
      "enum": [
        "Firm",
        "Location",
        "Salesperson"
      ]
    },
    "addressCategoryId": {
      "type": "string",
      "enum": [
        "Storefront",
        "MainOffice",
        "Warehouse",
        "Salesperson",
        "Other"
      ]
    },
    "line1": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "region": {
      "type": "string"
    },
    "postalCode": {
      "type": "string"
    },
    "country": {
      "type": "string"
    }
  }
}