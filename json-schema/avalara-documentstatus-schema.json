{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/DocumentStatus",
  "title": "DocumentStatus",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Pending",
        "Accepted",
        "Rejected",
        "Error"
      ]
    },
    "statusDate": {
      "type": "string",
      "format": "date-time"
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/DocumentEvent"
      }
    }
  }
}