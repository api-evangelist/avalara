{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/FilingResponse",
  "title": "FilingResponse",
  "type": "object",
  "properties": {
    "filingId": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Accepted",
        "Processing",
        "Rejected"
      ]
    },
    "formCount": {
      "type": "integer"
    },
    "submittedDate": {
      "type": "string",
      "format": "date-time"
    }
  }
}