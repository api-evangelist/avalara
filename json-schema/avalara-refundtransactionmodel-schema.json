{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/RefundTransactionModel",
  "title": "RefundTransactionModel",
  "type": "object",
  "required": [
    "refundTransactionCode",
    "refundDate",
    "refundType"
  ],
  "properties": {
    "refundTransactionCode": {
      "type": "string"
    },
    "refundDate": {
      "type": "string",
      "format": "date"
    },
    "refundType": {
      "type": "string",
      "enum": [
        "Full",
        "Partial",
        "Percentage",
        "TaxOnly"
      ]
    },
    "refundPercentage": {
      "type": "number",
      "format": "double"
    },
    "refundLines": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}